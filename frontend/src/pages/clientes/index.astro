---
import MainLayout from '../../layouts/MainLayout.astro';
import ClientList from '../../components/ClientList';
---

<MainLayout title="Clientes">
  <div class="space-y-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h2 class="text-2xl font-bold text-primary">Clientes</h2>
      <a href="/clientes/nuevo" class="bg-blue-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors shadow-sm sm:self-start">
        + Nuevo
      </a>
    </div>

    <!-- React Island -->
    <ClientList client:load />

  </div>
</MainLayout>
