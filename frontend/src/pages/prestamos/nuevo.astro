---
import MainLayout from '../../layouts/MainLayout.astro';
import NewLoanWizard from '../../components/NewLoanWizard';
---

<MainLayout title="Nuevo Préstamo">
  <div class="space-y-6">
    <div class="flex items-center gap-3">
      <a href="/clientes" class="p-2 bg-slate-100 rounded-full text-slate-500 hover:bg-slate-200">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h2 class="text-2xl font-bold text-primary">Originación</h2>
    </div>

    <!-- React Island Wizard -->
    <NewLoanWizard client:load />

  </div>
</MainLayout>
