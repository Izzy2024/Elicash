DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:4322"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_RESET_SECRET="replace-with-a-different-long-random-secret"
BCRYPT_ROUNDS=12
REGISTRATION_INVITE_CODE="optional-invite-code-for-production"
# Con el proxy /api/* de Netlify (netlify.toml) la cookie es first-party:
# deja COOKIE_DOMAIN vacío y COOKIE_SAME_SITE en "strict".
# Solo usa "none" si el frontend llama al backend directo cross-site (no recomendado).
COOKIE_DOMAIN=""
COOKIE_SAME_SITE="strict"
RESEND_API_KEY="your-resend-api-key"
FROM_EMAIL="onboarding@resend.dev"
